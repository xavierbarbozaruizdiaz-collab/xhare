# Copy to .env and fill with your Supabase project values.
# Expo (SDK 49+) uses EXPO_PUBLIC_ for client-side env.

# Variante de app (una sola app JS; el binario nativo se genera por sabor).
# passenger → paquete com.xhare.app, pestaña Pasajero. driver → com.xhare.driver, pestaña Conductor.
# En desarrollo: preferí los scripts npm android:passenger / android:driver (no hace falta duplicar aquí).
# EXPO_PUBLIC_APP_FLAVOR=passenger

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL del backend Next.js (Vercel o tu dominio). Sin esto:
# - No se ejecuta el cálculo por tramo (segment-stats) en reservas con paradas → se usa tarifa mínima.
# - Tampoco: push/register, valoraciones, ensure-driver-pending, extra-stops, arrive.
# Reemplazá por tu URL real (sin barra final).
EXPO_PUBLIC_API_BASE_URL=https://transporte-beige.vercel.app

# Android: para que el mapa en "Reservar" se vea (no en blanco), crear en Google Cloud
# una API key con "Maps SDK for Android" y ponerla aquí (o en EAS Secrets como GOOGLE_MAPS_ANDROID_API_KEY).
# GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key
