{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/start-metro-android.cjs",
    "start:clear": "node scripts/start-metro-android.cjs --clear",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "start:passenger": "cross-env APP_FLAVOR=passenger node scripts/start-metro-android.cjs",
    "start:driver": "cross-env APP_FLAVOR=driver node scripts/start-metro-android.cjs",
    "android": "expo run:android --variant debug",
    "android:run": "expo run:android --variant debug",
    "android:passenger": "cross-env APP_FLAVOR=passenger expo run:android --variant debug",
    "android:driver": "cross-env APP_FLAVOR=driver expo run:android --variant debug",
    "android:passenger:no-bundler": "cross-env APP_FLAVOR=passenger node scripts/run-android-debug-no-bundler.cjs",
    "android:driver:no-bundler": "cross-env APP_FLAVOR=driver node scripts/run-android-debug-no-bundler.cjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "npm run check:ts",
    "check:ts": "tsc --noEmit",
    "icons:android": "cross-env APP_FLAVOR=passenger node scripts/sync-android-launcher-icons.cjs",
    "build:android:release": "cd android && gradlew.bat clean && cd .. && npx expo run:android --variant release -p 8082",
    "build:android:cloud:apk:preview": "eas build --platform android --profile preview",
    "build:android:cloud:apk:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "~55.0.6",
    "expo-constants": "^55.0.7",
    "expo-linking": "^55.0.7",
    "expo-location": "^55.1.2",
    "expo-notifications": "^55.0.12",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "1.26.20",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
